#------------------------------------------------------
#OBRIGATORIO: gere com:
#  python3 -c "import secrets; print(secrets.token_hex(32))"
#------------------------------------------------------
SECRET_KEY=COLOQUE_AQUI_SUA_CHAVE_SECRETA

#------------------------------------------------------
#BANCO DE DADOS MariaDB/MySQL
#Formato: mysql+pymysql://usuario:senha@localhost:3306/nome_do_banco
#------------------------------------------------------
DATABASE_URL=mysql+pymysql://usuario:senha@localhost:3306/nome_do_banco

#------------------------------------------------------
#URL publica da aplicacao (sem barra no final)
#------------------------------------------------------
APP_BASE_URL=https://seudominio.com.br

#------------------------------------------------------
#Dados da empresa (aparecem no sistema e nas mensagens WhatsApp)
#------------------------------------------------------
COMPANY_NAME=Nome da Sua Empresa
COMPANY_WHATSAPP=5598999999999

#------------------------------------------------------
#Fuso horario e alertas
#------------------------------------------------------
APP_TIMEZONE=America/Sao_Paulo
ALERT_WINDOW_DAYS=3

#------------------------------------------------------
#Admin inicial (criado automaticamente pelo init_db.py)
#------------------------------------------------------
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@suaempresa.com
ADMIN_PASSWORD=troque-esta-senha

#------------------------------------------------------
#Mercado Pago (opcional — deixe vazio para desativar)
#------------------------------------------------------
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
